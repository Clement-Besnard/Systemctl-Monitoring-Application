{
  "name": "systemctl",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev":         "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server":  "cd api && nodemon --ignore favorites.json server.js",
    "dev:client":  "vite --host",
    "build":       "vite build --host",
    "preview":     "vite preview"
  },
  "dependencies": {
    "react":            "^18.3.0",
    "react-dom":        "^18.3.0",
    "react-router-dom": "^6.26.0",
    "dotenv":           "^16.0.0",
    "express":          "^4.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite":                 "^5.4.0",
    "concurrently":         "^9.0.0",
    "nodemon":              "^3.0.0"
  }
}